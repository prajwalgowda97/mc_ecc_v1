	{[format {zmc_top.dut.o_ECC_STAUS_REG[31:0]}]}
	} ]]
set id [waveform add -signals [subst  {
	{[format {zmc_top.dut.ECC_interrupt}]}
	} ]]

waveform xview limits 163820ns 164398ns
